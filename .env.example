# ══════════════════════════════════════════════════════════════════════════════
# FASHIONISTAR FRONTEND — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to Git.
# ══════════════════════════════════════════════════════════════════════════════

# ── App Identity ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=FASHIONISTAR AI
NEXT_PUBLIC_VERSION=2.0.0
NEXT_PUBLIC_ENV=development

# ── Backend API (Django) ── REQUIRED ─────────────────────────────────────────
# DRF Sync endpoints — Auth, Orders, Products, Payments
NEXT_PUBLIC_API_V1_URL=https://hydrographically-tawdrier-hayley.ngrok-free.dev/api
# Ninja Async endpoints — AI, Search, Analytics
NEXT_PUBLIC_API_V2_URL=https://hydrographically-tawdrier-hayley.ngrok-free.dev/api/v1/ninja
# Raw backend base (no /api suffix) — used by rewrites in next.config.mjs
NEXT_PUBLIC_BACKEND_URL=https://hydrographically-tawdrier-hayley.ngrok-free.dev

# ── Frontend App URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cloudflare Quick Tunnel (random URL per session — run: make tunnel-frontend)
# Copy the trycloudflare.com URL printed after startup here.
NEXT_PUBLIC_FRONTEND_TUNNEL_URL=https://YOUR_CLOUDFLARE_TUNNEL.trycloudflare.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Cloudinary CDN ── from fashionistar_backend/.env ─────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD=dgpdlknc1
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=fashionista_ai
CLOUDINARY_API_KEY=965289429995279
CLOUDINARY_API_SECRET=I76o1iQ3pTR1sDTpj0qXrbu5eVE

# ── Auth / Session ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=fashionistar_super_secret_key_change_in_production_32chars
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=fashionistar_jwt_secret_key_change_in_production

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=fashionistar
SENTRY_PROJECT=fashionistar-frontend

# ── Payments ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G_MEASUREMENT_ID
NEXT_PUBLIC_OTEL_ENABLED=false
NEXT_PUBLIC_OTEL_ENDPOINT=http://localhost:4318

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_AI_MEASUREMENTS=true
NEXT_PUBLIC_FEATURE_SOCIAL_LOGIN=true
NEXT_PUBLIC_FEATURE_BETA_CHECKOUT=false

# ── Internationalization ──────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,fr,es,pt,ar

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_SERVICE_URL=https://api.resend.com/emails
EMAIL_FROM=noreply@fashionistar.com
EMAIL_API_KEY=your_email_api_key

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
DEBUG_STORAGE=false
NEXT_PUBLIC_VERBOSE_ERROR=false
